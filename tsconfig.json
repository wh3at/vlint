{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "types": ["bun"]
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
